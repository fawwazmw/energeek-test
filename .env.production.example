# ==============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control!

# Application
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_URL=https://yourdomain.com

# Database (Use strong passwords!)
DB_DATABASE=energeek_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Ports (optional, defaults shown)
HTTP_PORT=80
# HTTPS_PORT=443  # Uncomment if using SSL

# ==============
# NOTES:
# ==============
# 1. Generate APP_KEY: docker-compose -f docker-compose.prod.yml run --rm backend php artisan key:generate --show
# 2. Use strong random passwords for DB_PASSWORD (at least 20 chars)
# 3. Set APP_URL to your actual domain
# 4. For HTTPS, use a reverse proxy like Caddy or Traefik
